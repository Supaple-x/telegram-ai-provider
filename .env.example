# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI (fallback when Claude is unavailable)
OPENAI_API_KEY=your_openai_key_here

# Google GenAI (image generation with Imagen 4, requires billing)
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql://bot:bot_password@postgres:5432/telegram_bot

# Access control: comma-separated Telegram user IDs and/or usernames
# Empty = unrestricted access (anyone can use the bot)
ALLOWED_USERS=Zhagell,HolmesSherlok

# Rate limiting (per user)
RATE_LIMIT_MESSAGES=10
RATE_LIMIT_WINDOW=60

# Auto-cleanup messages older than N days (0 = disabled)
MESSAGES_TTL_DAYS=30
